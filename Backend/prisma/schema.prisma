// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Lead {
  id            Int      @id @default(autoincrement())

  // Basic Info (from Maps)
  name          String?
  address       String?
  website       String?
  hasWebsite    Boolean?
  phone         String?

  // Enriched Info
  email         String?  @unique
  company       String?
  linkedinUrl   String?

  // Location
  country       String?
  state         String?
  city          String?
  area          String?

  // System Fields
  source        String?   // google_maps, website, apollo
  status        String    @default("NEW")
  icpScore      Float?

  // Pipeline Tracking
  mapsScraped       Boolean @default(false)
  websiteVisited    Boolean @default(false)
  emailExtracted    Boolean @default(false)
  contacted         Boolean @default(false)

  // Deduplication Key
  uniqueKey     String? @unique

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("leads")
}

model ScrapingJob {
  id        Int      @id @default(autoincrement())
  url       String
  status    String   @default("PENDING")
  results   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("scraping_jobs")
}
