// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Lead {
  id            Int      @id @default(autoincrement())

  // Basic Info (from Maps)
  name          String?
  address       String?
  website       String?
  hasWebsite    Boolean?
  phone         String?
  keyword       String?
  
  // Enriched Info
  email         String?  @unique
  company       String?
  linkedinUrl   String?

  // Location
  country       String?
  state         String?
  city          String?
  area          String?

  // System Fields
  source        String?   // google_maps, website, apollo
  status        String    @default("NEW")
  icpScore      Float?

  // Pipeline Tracking
  mapsScraped       Boolean @default(false)
  websiteVisited    Boolean @default(false)
  emailExtracted    Boolean @default(false)
  contacted         Boolean @default(false)

  // Deduplication Key
  uniqueKey     String? @unique

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  scrapingJobId Int?
  scrapingJob   ScrapingJob? @relation(fields: [scrapingJobId], references: [id])

  @@map("leads")
}

model ScrapingJob {
  id        Int      @id @default(autoincrement())
  url       String
  status    String   @default("PENDING")
  results   Int      @default(0)

  leads     Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("scraping_jobs")
}
